# ── Grafik-bot production .env ──────────────────────────────────────────────
# Copy to the repo root as `.env` on the server and fill in real values.
# Never commit the real .env to git.

# Port the Node app listens on (the reverse proxy forwards to it). 8080 is fine.
PORT=8080

# Node environment — MUST be "production" on the server (enables secure cookies).
# (pm2 ecosystem.config.cjs already sets this, but keep it here too.)
NODE_ENV=production

# PostgreSQL connection. For a local DB created per DEPLOY.md:
DATABASE_URL=postgresql://grafik:CHANGE_ME_DB_PASSWORD@localhost:5432/grafik_bot

# Public URL of the panel (shown to users in the bot, e.g. login link).
# Free option (no domain): https://YOUR_SERVER_IP.sslip.io   e.g. https://91.2.3.4.sslip.io
# With a real domain:       https://your-domain.com
WEB_PUBLIC_URL=https://YOUR_SERVER_IP.sslip.io

# ── Telegram bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:your-bot-token-from-BotFather
TELEGRAM_BOT_USERNAME=Your_bot_username   # without @

# ── Web session security ────────────────────────────────────────────────────
# 64+ random chars. Generate with:  openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_64_RANDOM_CHARS

# Same-origin panel → CORS not needed. Leave empty unless you serve the SPA
# from a different domain (then comma-separated origins).
CORS_ORIGINS=

LOG_LEVEL=info

# ── OPTIONAL: Google Drive export (schedules/reports/hours to Drive) ─────────
# Service account (for reading the availability Google Sheet, if used):
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
ADMIN_GOOGLE_EMAIL=
# OAuth (uploads files to YOUR Drive — service accounts have no Drive quota):
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── OPTIONAL: SMTP (emailing the approved schedule to factory clients) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
